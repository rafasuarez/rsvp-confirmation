# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# Local: matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/topaz_ibis_dev?schema=public

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Session ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# ─── WhatsApp Business Cloud API ──────────────────────────────────────────────
# From Meta Developer Console → App → WhatsApp → Configuration
WA_VERIFY_TOKEN=your_webhook_verify_token_here
WA_APP_SECRET=your_app_secret_here
WA_ACCESS_TOKEN=your_permanent_system_user_token_here
WA_API_VERSION=v19.0
WA_PHONE_NUMBER_ID=your_phone_number_id_here

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
